# Copy this file to .env for local development.
# Do not commit .env; it should contain your real API key.

PROCESSING_MODE=llm
LLM_PROVIDER=azure_foundry

# Azure AI Foundry / Serverless OpenAI-compatible endpoint
AZURE_FOUNDRY_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com/api/projects/YOUR-PROJECT/openai/v1/
AZURE_FOUNDRY_API_KEY=replace-with-your-foundry-key
AZURE_FOUNDRY_DEPLOYMENT=gpt-4.1-mini
AZURE_FOUNDRY_REQUEST_TIMEOUT_SECONDS=5
AZURE_FOUNDRY_CONNECT_TIMEOUT_SECONDS=2
AZURE_FOUNDRY_MAX_OUTPUT_TOKENS=320
AZURE_FOUNDRY_MAX_IMAGE_LONG_EDGE=768
AZURE_FOUNDRY_JPEG_QUALITY=48

# Optional local OCR path for offline testing mode
ALLOW_LOCAL_OCR=true
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Debug output should remain false in deployed environments
SHOW_RAW_EXTRACTION=false

# Batch controls
LLM_BATCH_PARALLELISM=2
LOCAL_OCR_BATCH_PARALLELISM=2
MAX_IMAGES_PER_PRODUCT=4
